{
  "entities": {
    "ToTAnalysisResult": {
      "title": "ToTAnalysisResult",
      "description": "Tree of Thoughts analysis results generated by ARGUS Predictive Command",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "feedId": {
          "type": "string"
        },
        "feedTitle": {
          "type": "string"
        },
        "feedType": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "entropyScore": {
          "type": "number"
        },
        "finalDecision": {
          "type": "string"
        },
        "cached": {
          "type": "boolean"
        },
        "durationMs": {
          "type": "number"
        },
        "userId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "feedId",
        "feedTitle",
        "feedType",
        "timestamp",
        "entropyScore",
        "finalDecision"
      ]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Alert subscription details for operators",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "alertThreshold": {
          "type": "number"
        },
        "customBriefing": {
          "type": "boolean"
        },
        "registeredAt": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        }
      },
      "required": [
        "email",
        "alertThreshold",
        "customBriefing",
        "registeredAt"
      ]
    },
    "GmailMessage": {
      "title": "GmailMessage",
      "description": "Real Gmail emails synchronized from the secure Google API to enable real-time disconnected telemetry",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "snippet": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "isUnread": {
          "type": "boolean"
        },
        "isImportant": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "from",
        "subject",
        "snippet",
        "date",
        "to",
        "timestamp"
      ]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "Google Calendar events synchronized and stored in Firestore for offline resilience",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "startTime": {
          "type": "string"
        },
        "endTime": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "routePresetId": {
          "type": "string"
        },
        "timestamp": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "title",
        "startTime",
        "endTime",
        "userId",
        "timestamp"
      ]
    },
    "KeepNote": {
      "title": "KeepNote",
      "description": "Tactical operators' notes synchronized in Google Keep format",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "isList": {
          "type": "boolean"
        },
        "listItems": {
          "type": "array"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": [
        "userId",
        "title",
        "text",
        "timestamp"
      ]
    },
    "TelemetryLog": {
      "title": "TelemetryLog",
      "description": "System transaction log for direct Sheets / Drive / Calendar sync monitoring",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "status": {
          "type": "number"
        },
        "responseSize": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "endpoint",
        "status",
        "responseSize",
        "timestamp",
        "userId"
      ]
    },
    "APILog": {
      "title": "APILog",
      "description": "Logging transactions of Keep API requests",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "status": {
          "type": "number"
        },
        "responseSize": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "endpoint",
        "status",
        "responseSize",
        "timestamp"
      ]
    },
    "TestConnection": {
      "title": "TestConnection",
      "description": "Mock connection test collection for Firebase initialization validation",
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        }
      }
    }
  },
  "firestore": {
    "decisions/{decisionId}": {
      "schema": "ToTAnalysisResult",
      "description": "Collection of all ToT decision logs"
    },
    "subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "Collection of custom operator alert subscriptions"
    },
    "gmail_messages/{messageId}": {
      "schema": "GmailMessage",
      "description": "Real Gmail messages synced by active operators for offline resilient telemetry"
    },
    "calendar_events/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Collection of synced or scheduled itinerary calendar events"
    },
    "keep_notes/{noteId}": {
      "schema": "KeepNote",
      "description": "Collection of Keep notes synchronised in Firestore"
    },
    "telemetry_logs/{logId}": {
      "schema": "TelemetryLog",
      "description": "Collection of API call telemetry logs"
    },
    "api_logs/{logId}": {
      "schema": "APILog",
      "description": "Collection of Keep API logs"
    },
    "test/{testId}": {
      "schema": "TestConnection",
      "description": "Collection of test connections on boot"
    }
  }
}
